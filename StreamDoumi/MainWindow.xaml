<Window x:Class="StreamDoumi.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="StreamDoumi"
        Icon="icon.ico"
        Height="820"
        Width="1280"
        MinHeight="720"
        MinWidth="1080"
        Background="#0F1117"
        FontFamily="Segoe UI">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#181B23" />
        <SolidColorBrush x:Key="PanelAltBrush" Color="#20242E" />
        <SolidColorBrush x:Key="LineBrush" Color="#303642" />
        <SolidColorBrush x:Key="TextMainBrush" Color="#F5F7FA" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#9EA7B5" />
        <SolidColorBrush x:Key="AccentBrush" Color="#42D392" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="PillButton" TargetType="Button">
            <Setter Property="Foreground" Value="#07110C" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="GhostButton" BasedOn="{StaticResource PillButton}" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}" />
            <Setter Property="Background" Value="#252A35" />
            <Setter Property="BorderBrush" Value="#343B49" />
        </Style>

        <Style x:Key="PanelBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}" />
            <Setter Property="Background" Value="#252A35" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="#343B49"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}"
                                Margin="{TemplateBinding Margin}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#F5F7FA" />
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#F5F7FA" />
                                <Setter Property="Foreground" Value="#11151C" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="False">
                                <Setter Property="Foreground" Value="#F5F7FA" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#151922" />
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="Padding" Value="8,6" />
        </Style>

        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}" />
            <Setter Property="Margin" Value="0,0,14,0" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Background="Transparent" SnapsToDevicePixels="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border x:Name="CheckBoxGlyph"
                                    Width="15"
                                    Height="15"
                                    Background="#0F1117"
                                    BorderBrush="#8E98A8"
                                    BorderThickness="1"
                                    CornerRadius="2"
                                    VerticalAlignment="Center">
                                <Path x:Name="CheckMark"
                                      Data="M 3 7.5 L 6.2 10.5 L 12 4"
                                      Stroke="#07110C"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Visibility="Collapsed" />
                            </Border>
                            <ContentPresenter Grid.Column="1"
                                              Margin="7,0,0,0"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckBoxGlyph" Property="Background" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="CheckBoxGlyph" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckBoxGlyph" Property="BorderBrush" Value="#DDE4FF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid" Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid x:Name="HeaderPanel">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel x:Name="TitlePanel">
                <TextBlock Text="StreamDoumi" FontSize="34" FontWeight="Bold" />
                <TextBlock x:Name="HeaderSubtitleText"
                           Text="방송 전 앱 실행, 브라우저 열기, 창 배치를 한 번에 준비합니다."
                           Style="{StaticResource MutedText}"
                           Margin="0,4,0,0" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <ComboBox x:Name="LanguageComboBox"
                          Width="96"
                          Padding="8,6"
                          SelectionChanged="LanguageComboBox_SelectionChanged"
                          Margin="0,0,10,0">
                    <ComboBoxItem Content="한국어" Tag="ko" IsSelected="True" />
                    <ComboBoxItem Content="English" Tag="en" />
                    <ComboBoxItem Content="日本語" Tag="ja" />
                </ComboBox>
                <Border x:Name="AdminBadge"
                        Background="#271E22"
                        BorderBrush="#55303A"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12,8"
                        Margin="0,0,10,0">
                    <TextBlock x:Name="AdminBadgeText" Text="관리자모드 확인 중" Foreground="#FFB2BD" FontWeight="SemiBold" />
                </Border>
                <Button x:Name="SettingsButton" Style="{StaticResource GhostButton}" Content="설정" Click="SettingsButton_Click" MinWidth="58" Margin="0,0,10,0" />
                <Button x:Name="MiniModeButton" Style="{StaticResource GhostButton}" Content="계기판 모드" Click="MiniModeButton_Click" MinWidth="92" Margin="0,0,10,0" />
                <Button x:Name="SaveProfileButton" Style="{StaticResource GhostButton}" Content="프로필 저장" Click="SaveProfileButton_Click" MinWidth="92" Margin="0,0,10,0" />
                <Button x:Name="StartPrepButton" Style="{StaticResource PillButton}" Content="방송 준비 시작" Click="StartPrepButton_Click" MinWidth="114" />
            </StackPanel>
        </Grid>

        <Grid x:Name="ContentPanel" Grid.Row="1" Margin="0,22,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="ReadyListColumn" Width="320" />
                <ColumnDefinition x:Name="LayoutEditorColumn" Width="*" />
                <ColumnDefinition x:Name="IndicatorColumn" Width="330" />
            </Grid.ColumnDefinitions>

            <Border x:Name="ReadyListPanel" Style="{StaticResource PanelBorder}" Padding="18">
                <DockPanel LastChildFill="True">
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,14">
                        <TextBlock x:Name="ReadyListTitle" Text="준비 목록" FontSize="20" FontWeight="SemiBold" />
                    </Grid>

                    <StackPanel DockPanel.Dock="Bottom" Margin="0,16,0,0">
                        <Button x:Name="EditReadyItemButton" Style="{StaticResource GhostButton}" Content="속성 변경" Click="EditReadyItemButton_Click" Visibility="Collapsed" Margin="0,0,0,8" />
                        <Button x:Name="RemoveReadyItemButton" Style="{StaticResource GhostButton}" Content="항목 제거" Click="RemoveReadyItemButton_Click" Visibility="Collapsed" Margin="0,0,0,8" />
                        <Button x:Name="AddReadyItemButton" Style="{StaticResource GhostButton}" Content="항목 추가" Click="AddReadyItemButton_Click" />
                    </StackPanel>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="ReadyItemsPanel" />
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <Border x:Name="LayoutEditorPanel" Grid.Column="1" Style="{StaticResource PanelBorder}" Padding="18" Margin="18,0">
                <TabControl x:Name="MainTabControl">
                    <TabItem x:Name="LayoutTab" Header="배치">
                        <Grid Margin="0,16,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock x:Name="LayoutTitle" Text="창 배치 편집" FontSize="20" FontWeight="SemiBold" />
                                    <TextBlock x:Name="LayoutDescription"
                                               Text="실제 모니터 레이아웃에서 선택한 항목의 위치와 크기를 조정합니다."
                                               Style="{StaticResource MutedText}"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                                    <Button x:Name="SelectScreenRegionButton" Style="{StaticResource GhostButton}" Content="화면에서 지정" Click="SelectScreenRegionButton_Click" Margin="0,0,8,0" />
                                    <Button x:Name="ResetPlacementButton" Style="{StaticResource GhostButton}" Content="위치 초기화" Click="ResetPlacementButton_Click" />
                                </StackPanel>
                            </Grid>

                            <Border Grid.Row="1"
                                    Background="#10131A"
                                    BorderBrush="#2B3340"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Margin="0,18,0,14"
                                    ClipToBounds="True">
                                <Grid>
                                    <Canvas x:Name="LayoutCanvas"
                                            Background="#10131A"
                                            MouseLeftButtonDown="LayoutCanvas_MouseLeftButtonDown"
                                            SizeChanged="LayoutCanvas_SizeChanged">
                                        <Border x:Name="PlacementBox"
                                                Width="360"
                                                Height="220"
                                                Canvas.Left="84"
                                                Canvas.Top="72"
                                                Background="#3342D392"
                                                BorderBrush="{StaticResource AccentBrush}"
                                                BorderThickness="2"
                                                CornerRadius="6"
                                                Cursor="SizeAll"
                                                MouseLeftButtonDown="PlacementBox_MouseLeftButtonDown"
                                                MouseMove="PlacementBox_MouseMove"
                                                MouseLeftButtonUp="PlacementBox_MouseLeftButtonUp">
                                            <Grid>
                                                <TextBlock x:Name="PlacementBoxText"
                                                           Text="OBS Studio"
                                                           Foreground="#EFFFF7"
                                                           FontWeight="SemiBold"
                                                           Margin="12"
                                                           VerticalAlignment="Top" />
                                                <Thumb Tag="Left" Width="8" HorizontalAlignment="Left" Cursor="SizeWE" DragDelta="ResizeThumb_DragDelta" />
                                                <Thumb Tag="Right" Width="8" HorizontalAlignment="Right" Cursor="SizeWE" DragDelta="ResizeThumb_DragDelta" />
                                                <Thumb Tag="Top" Height="8" VerticalAlignment="Top" Cursor="SizeNS" DragDelta="ResizeThumb_DragDelta" />
                                                <Thumb Tag="Bottom" Height="8" VerticalAlignment="Bottom" Cursor="SizeNS" DragDelta="ResizeThumb_DragDelta" />
                                                <Thumb Tag="TopLeft" Width="16" Height="16" HorizontalAlignment="Left" VerticalAlignment="Top" Cursor="SizeNWSE" DragDelta="ResizeThumb_DragDelta" />
                                                <Thumb Tag="TopRight" Width="16" Height="16" HorizontalAlignment="Right" VerticalAlignment="Top" Cursor="SizeNESW" DragDelta="ResizeThumb_DragDelta" />
                                                <Thumb Tag="BottomLeft" Width="16" Height="16" HorizontalAlignment="Left" VerticalAlignment="Bottom" Cursor="SizeNESW" DragDelta="ResizeThumb_DragDelta" />
                                                <Thumb Tag="BottomRight" Width="16" Height="16" HorizontalAlignment="Right" VerticalAlignment="Bottom" Cursor="SizeNWSE" DragDelta="ResizeThumb_DragDelta" />
                                            </Grid>
                                        </Border>
                                    </Canvas>
                                    <CheckBox x:Name="SnapCheckBox"
                                              Content="창 이동 스냅기능 활성화"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Bottom"
                                              Margin="10"
                                              Foreground="{StaticResource TextMainBrush}"
                                              Background="#AA10131A"
                                              Checked="SnapCheckBox_Changed"
                                              Unchecked="SnapCheckBox_Changed" />
                                </Grid>
                            </Border>

                            <Grid Grid.Row="2" MinHeight="40">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="PositionText"
                                               Text="위치 : X 0 / Y 0"
                                               Style="{StaticResource MutedText}"
                                               TextWrapping="NoWrap" />
                                    <TextBlock x:Name="SizeText"
                                               Text="크기 : W 1280 / H 720"
                                               Style="{StaticResource MutedText}"
                                               TextWrapping="NoWrap"
                                               Margin="24,0,0,0" />
                                </StackPanel>
                                <TextBlock x:Name="MonitorText"
                                           Grid.Column="1"
                                           Text="모니터 1"
                                           Style="{StaticResource MutedText}"
                                           HorizontalAlignment="Right"
                                           TextWrapping="NoWrap"
                                           Margin="16,0,0,0" />
                                <TextBlock x:Name="TargetText"
                                           Grid.Row="1"
                                           Grid.ColumnSpan="2"
                                           Text="대상 : 없음"
                                           Style="{StaticResource MutedText}"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,5,0,0" />
                            </Grid>
                        </Grid>
                    </TabItem>

                    <TabItem x:Name="SettingsTab" Header="설정">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0,20,0,0" MaxWidth="620" HorizontalAlignment="Left">
                            <TextBlock x:Name="LaunchModeTitle" Text="실행 방식" FontSize="20" FontWeight="SemiBold" />
                            <TextBlock x:Name="LaunchModeDescription"
                                       Text="방송 준비 시작 버튼을 눌렀을 때 등록된 항목을 실행하는 순서를 정합니다."
                                       Style="{StaticResource MutedText}"
                                       Margin="0,4,0,18" />

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <RadioButton x:Name="SequentialLaunchRadio"
                                             Content="순차 실행"
                                             GroupName="LaunchMode"
                                             Checked="LaunchSettings_Changed" />
                                <RadioButton x:Name="ParallelLaunchRadio"
                                             Content="동시 실행"
                                             GroupName="LaunchMode"
                                             Checked="LaunchSettings_Changed" />
                            </StackPanel>

                            <CheckBox x:Name="UseLaunchDelayCheckBox"
                                      Content="순차 실행 시 간격 사용"
                                      Checked="LaunchSettings_Changed"
                                      Unchecked="LaunchSettings_Changed"
                                      Margin="0,0,0,10" />

                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock x:Name="LaunchDelayLabel" Text="실행 간격" VerticalAlignment="Center" Margin="0,0,10,0" />
                                <TextBox x:Name="LaunchDelayTextBox"
                                         Width="80"
                                         Text="3"
                                         TextChanged="LaunchDelayTextBox_TextChanged" />
                                <TextBlock x:Name="LaunchDelaySecondsLabel" Text="초" VerticalAlignment="Center" Margin="8,0,0,0" />
                            </StackPanel>

                            <TextBlock x:Name="NetworkSpeedTitle" Text="인터넷 최고속도" FontSize="20" FontWeight="SemiBold" Margin="0,28,0,4" />
                            <TextBlock x:Name="NetworkSpeedDescription"
                                       Text="계기판과 네트워크 상태 표시의 기준으로 사용할 최고 속도입니다. MB/s 단위로 입력합니다."
                                       Style="{StaticResource MutedText}"
                                       Margin="0,0,0,14" />

                            <Grid Margin="0,0,0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock x:Name="MaxDownloadSpeedLabel" Text="다운로드 최고속도" Margin="0,0,0,6" />
                                    <DockPanel>
                                        <TextBox x:Name="MaxDownloadSpeedTextBox"
                                                 Width="120"
                                                 Text="100"
                                                 TextChanged="NetworkSpeedTextBox_TextChanged" />
                                        <TextBlock Text="MB/s" VerticalAlignment="Center" Margin="8,0,0,0" />
                                    </DockPanel>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock x:Name="MaxUploadSpeedLabel" Text="업로드 최고속도" Margin="0,0,0,6" />
                                    <DockPanel>
                                        <TextBox x:Name="MaxUploadSpeedTextBox"
                                                 Width="120"
                                                 Text="100"
                                                 TextChanged="NetworkSpeedTextBox_TextChanged" />
                                        <TextBlock Text="MB/s" VerticalAlignment="Center" Margin="8,0,0,0" />
                                    </DockPanel>
                                </StackPanel>
                            </Grid>

                            <TabControl Margin="0,28,0,0">
                                <TabItem x:Name="BrowserPathTab" Header="기본 브라우저 경로">
                                    <StackPanel Margin="0,16,0,0">
                            <TextBlock x:Name="BrowserPathTitle" Text="브라우저 경로" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <TextBlock x:Name="BrowserPathDescription"
                                       Text="감지된 실행 파일 경로입니다. 브라우저 업데이트나 설치 위치 변경 시 직접 수정할 수 있습니다."
                                       Style="{StaticResource MutedText}"
                                       Margin="0,0,0,14" />

                            <TextBlock Text="Microsoft Edge" Margin="0,0,0,6" />
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="EdgePathTextBox" TextChanged="BrowserPathTextBox_TextChanged" />
                                <Button x:Name="BrowseEdgeButton" Grid.Column="1" Style="{StaticResource GhostButton}" Content="찾기" Tag="Edge" Click="BrowseBrowserPathButton_Click" Margin="8,0,0,0" />
                            </Grid>

                            <TextBlock Text="Google Chrome" Margin="0,0,0,6" />
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="ChromePathTextBox" TextChanged="BrowserPathTextBox_TextChanged" />
                                <Button x:Name="BrowseChromeButton" Grid.Column="1" Style="{StaticResource GhostButton}" Content="찾기" Tag="Chrome" Click="BrowseBrowserPathButton_Click" Margin="8,0,0,0" />
                            </Grid>

                            <TextBlock Text="Brave" Margin="0,0,0,6" />
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="BravePathTextBox" TextChanged="BrowserPathTextBox_TextChanged" />
                                <Button x:Name="BrowseBraveButton" Grid.Column="1" Style="{StaticResource GhostButton}" Content="찾기" Tag="Brave" Click="BrowseBrowserPathButton_Click" Margin="8,0,0,0" />
                            </Grid>

                            <TextBlock Text="Firefox" Margin="0,0,0,6" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="FirefoxPathTextBox" TextChanged="BrowserPathTextBox_TextChanged" />
                                <Button x:Name="BrowseFirefoxButton" Grid.Column="1" Style="{StaticResource GhostButton}" Content="찾기" Tag="Firefox" Click="BrowseBrowserPathButton_Click" Margin="8,0,0,0" />
                            </Grid>
                                    </StackPanel>
                                </TabItem>

                                <TabItem x:Name="CustomBrowserTab" Header="커스텀 브라우저 추가">
                                    <StackPanel Margin="0,16,0,0">
                            <TextBlock x:Name="CustomBrowserTitle" Text="커스텀 브라우저 추가" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <TextBlock x:Name="CustomBrowserDescription"
                                       Text="Opera GX처럼 기본 목록에 없는 브라우저를 직접 추가합니다."
                                       Style="{StaticResource MutedText}"
                                       Margin="0,0,0,14" />

                            <TextBlock x:Name="CustomBrowserNameLabel" Text="표시 이름" Margin="0,0,0,6" />
                            <TextBox x:Name="CustomBrowserNameTextBox" Margin="0,0,0,10" />

                            <TextBlock x:Name="CustomBrowserPathLabel" Text="실행 파일 경로" Margin="0,0,0,6" />
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="CustomBrowserPathTextBox" />
                                <Button x:Name="BrowseCustomBrowserButton" Grid.Column="1" Style="{StaticResource GhostButton}" Content="찾기" Click="BrowseCustomBrowserPathButton_Click" Margin="8,0,0,0" />
                            </Grid>

                            <Button x:Name="AddCustomBrowserButton" Style="{StaticResource PillButton}" Content="커스텀 브라우저 추가" Click="AddCustomBrowserButton_Click" HorizontalAlignment="Left" Margin="0,0,0,14" />

                            <ItemsControl x:Name="CustomBrowserList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#20242E" BorderBrush="#303642" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding Path}" Style="{StaticResource MutedText}" Margin="0,4,0,0" />
                                                </StackPanel>
                                                <Button Grid.Column="1" Style="{StaticResource GhostButton}" Content="삭제" Tag="{Binding Id}" Click="RemoveCustomBrowserButton_Click" Margin="10,0,0,0" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                                    </StackPanel>
                                </TabItem>
                            </TabControl>
                        </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem x:Name="InfoTab" Header="정보">
                        <ScrollViewer x:Name="InfoScrollViewer"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="0,20,0,0"
                                        MaxWidth="{Binding ViewportWidth, ElementName=InfoScrollViewer}"
                                        HorizontalAlignment="Stretch">
                                <TextBlock Text="StreamDoumi" FontSize="22" FontWeight="SemiBold" />
                                <TextBlock x:Name="InfoPurposeText"
                                           Text="방송 준비에 필요한 앱 실행, 브라우저 열기, 창 위치 배치를 한 번에 준비하는 개인 제작 도구입니다."
                                           Style="{StaticResource MutedText}"
                                           Margin="0,6,0,22" />

                                <TextBlock x:Name="InfoUsageTitle" Text="사용 방법" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8" />
                                <TextBlock x:Name="InfoUsageText" Style="{StaticResource MutedText}" Margin="0,0,0,20">
                                    <Run Text="1. 준비 목록에 앱, 브라우저, 바로가기를 추가합니다." />
                                    <LineBreak />
                                    <Run Text="2. 배치 탭에서 실행 후 놓일 위치와 크기를 조정합니다." />
                                    <LineBreak />
                                    <Run Text="3. 설정 탭에서 순차 실행 또는 동시 실행 방식을 선택합니다." />
                                    <LineBreak />
                                    <Run Text="4. 방송 준비 시작 버튼으로 등록한 항목을 실행합니다." />
                                </TextBlock>

                                <TextBlock x:Name="InfoNoticeTitle" Text="주의 사항" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8" />
                                <TextBlock x:Name="InfoNoticeText" Style="{StaticResource MutedText}" Margin="0,0,0,20">
                                    <Run Text="이 프로그램은 관리자 권한 실행, 외부 앱 실행, 창 위치 이동 기능을 사용합니다." />
                                    <LineBreak />
                                    <Run Text="개인 제작 앱 특성상 일부 백신이나 멀웨어 감지 프로그램에서 오탐으로 감지될 수 있습니다." />
                                    <LineBreak />
                                    <Run Text="불안한 경우 GitHub에 공개된 소스코드를 확인한 뒤 사용해 주세요." />
                                </TextBlock>

                                <TextBlock x:Name="InfoGithubTitle" Text="GitHub" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8" />
                                <TextBlock Text="https://github.com/chomiles/"
                                           Style="{StaticResource MutedText}"
                                           Margin="0,0,0,20" />

                                <TextBlock x:Name="InfoCreditText"
                                           Text="모든 시작을 응원하며 - 조마일즈"
                                           Foreground="{StaticResource TextMainBrush}"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </Border>

            <Border x:Name="IndicatorPanel" Grid.Column="2" Style="{StaticResource PanelBorder}" Padding="18">
                <ScrollViewer x:Name="IndicatorScrollViewer" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="IndicatorStack">
                        <TextBlock x:Name="IndicatorTitle"
                                   Text="시스템 상태"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   Margin="0,0,0,16" />
                        <TextBlock x:Name="IndicatorDescription"
                                   Text="0.5초 단위 갱신 기준. 90% 이상은 빨간색으로 표시합니다."
                                   Style="{StaticResource MutedText}"
                                   Visibility="Collapsed" />
                        <TextBlock x:Name="MiniSummaryText"
                                   Text="D 0.0  U 0.0  CPU 0%  GPU 0%"
                                   Visibility="Collapsed"
                                   FontSize="12"
                                   FontWeight="SemiBold" />

                        <Border x:Name="MiniGaugePanel"
                                Visibility="Collapsed"
                                Background="#080A0F"
                                BorderBrush="#2E3541"
                                BorderThickness="2"
                                CornerRadius="8"
                                Padding="10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,6">
                                    <Ellipse x:Name="MiniCpuDot" Width="7" Height="7" Fill="#42D392" Margin="4,0" />
                                    <Ellipse x:Name="MiniMemoryDot" Width="7" Height="7" Fill="#42D392" Margin="4,0" />
                                    <Ellipse x:Name="MiniUploadDot" Width="7" Height="7" Fill="#42D392" Margin="4,0" />
                                    <Ellipse x:Name="MiniDownloadDot" Width="7" Height="7" Fill="#42D392" Margin="4,0" />
                                    <Ellipse x:Name="MiniGpu0Dot" Width="7" Height="7" Fill="#42D392" Margin="4,0" />
                                    <Ellipse x:Name="MiniGpu1Dot" Width="7" Height="7" Fill="#42D392" Margin="4,0" />
                                </StackPanel>

                                <Grid Grid.Row="1" Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                    <TextBlock x:Name="MiniCpuLabel"
                                               Text="CPU"
                                               Foreground="#52E5D7"
                                               FontSize="12"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center" />
                                    <TextBlock x:Name="MiniCpuValueText"
                                               Text="42%"
                                               Foreground="#DDE4FF"
                                               FontFamily="Consolas"
                                               FontSize="28"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               LineHeight="30" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock x:Name="MiniMemoryLabel"
                                                   Text="MEM"
                                                   Foreground="#52E5D7"
                                                   FontSize="12"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center" />
                                        <TextBlock x:Name="MiniMemoryValueText"
                                                   Text="0%"
                                                   Foreground="#DDE4FF"
                                                   FontFamily="Consolas"
                                                   FontSize="28"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   LineHeight="30" />
                                    </StackPanel>
                                </Grid>

                                <Grid Grid.Row="2" Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock x:Name="MiniUpLabel"
                                                   Text="NET UP"
                                                   Foreground="#52E5D7"
                                                   FontSize="11"
                                                   FontWeight="Bold" />
                                        <TextBlock x:Name="MiniUpValueText"
                                                   Text="0.0 MB/s"
                                                   Foreground="#DDE4FF"
                                                   FontFamily="Consolas"
                                                   FontSize="15"
                                                   FontWeight="Bold" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                        <TextBlock x:Name="MiniDownLabel"
                                                   Text="NET DOWN"
                                                   Foreground="#52E5D7"
                                                   FontSize="11"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Right" />
                                        <TextBlock x:Name="MiniDownValueText"
                                                   Text="0.0 MB/s"
                                                   Foreground="#DDE4FF"
                                                   FontFamily="Consolas"
                                                   FontSize="15"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Right" />
                                    </StackPanel>
                                </Grid>

                                <Grid Grid.Row="3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock x:Name="MiniGpu0Label"
                                                   Text="GPU1"
                                                   Foreground="#52E5D7"
                                                   FontSize="11"
                                                   FontWeight="Bold" />
                                        <TextBlock x:Name="MiniGpu0ValueText"
                                                   Text="0%"
                                                   Foreground="#DDE4FF"
                                                   FontFamily="Consolas"
                                                   FontSize="22"
                                                   FontWeight="Bold" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                        <TextBlock x:Name="MiniGpu1Label"
                                                   Text="GPU2"
                                                   Foreground="#52E5D7"
                                                   FontSize="11"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Right" />
                                        <TextBlock x:Name="MiniGpu1ValueText"
                                                   Text="0%"
                                                   Foreground="#DDE4FF"
                                                   FontFamily="Consolas"
                                                   FontSize="22"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Right" />
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border x:Name="NetworkCard" Background="{StaticResource PanelAltBrush}" CornerRadius="8" Padding="14" Margin="0,0,0,12">
                            <StackPanel>
                                <Grid>
                                    <TextBlock x:Name="NetworkTitleText" Text="네트워크" FontWeight="SemiBold" FontSize="16" />
                                    <TextBlock x:Name="NetworkStateText" Text="좋음" HorizontalAlignment="Right" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" />
                                </Grid>
                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock x:Name="DownloadLabelText" Text="다운로드" Style="{StaticResource MutedText}" />
                                        <TextBlock x:Name="DownloadText" Text="18.4 MB/s" FontSize="24" FontWeight="SemiBold" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock x:Name="UploadLabelText" Text="업로드" Style="{StaticResource MutedText}" />
                                        <TextBlock x:Name="UploadText" Text="5.2 MB/s" FontSize="24" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Grid>
                                <Canvas x:Name="NetworkChart" Height="49" Margin="0,14,0,0" />
                            </StackPanel>
                        </Border>

                        <Border x:Name="CpuCard" Background="{StaticResource PanelAltBrush}" CornerRadius="8" Padding="14" Margin="0,0,0,12">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="CpuNameText"
                                               Text="CPU"
                                               FontWeight="SemiBold"
                                               FontSize="13"
                                               TextTrimming="CharacterEllipsis"
                                               TextWrapping="NoWrap"
                                               VerticalAlignment="Center"
                                               Margin="0,0,10,0" />
                                    <TextBlock x:Name="CpuText"
                                               Grid.Column="1"
                                               Text="42%"
                                               HorizontalAlignment="Right"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               TextWrapping="NoWrap" />
                                </Grid>
                                <ProgressBar x:Name="CpuBar" Height="10" Value="42" Maximum="100" Margin="0,12,0,0" />
                                <Grid Margin="0,14,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="MemoryNameText"
                                               Text="메모리"
                                               FontWeight="SemiBold"
                                               FontSize="13"
                                               TextTrimming="CharacterEllipsis"
                                               TextWrapping="NoWrap"
                                               VerticalAlignment="Center"
                                               Margin="0,0,10,0" />
                                    <TextBlock x:Name="MemoryText"
                                               Grid.Column="1"
                                               Text="0%"
                                               HorizontalAlignment="Right"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               TextWrapping="NoWrap" />
                                </Grid>
                                <ProgressBar x:Name="MemoryBar" Height="10" Value="0" Maximum="100" Margin="0,12,0,0" />
                            </StackPanel>
                        </Border>

                        <ItemsControl x:Name="GpuList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource PanelAltBrush}" CornerRadius="8" Padding="14" Margin="0,0,0,12">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Name}"
                                                           Foreground="{Binding NameBrush}"
                                                           FontWeight="SemiBold"
                                                           FontSize="16"
                                                           TextTrimming="CharacterEllipsis"
                                                           TextWrapping="NoWrap"
                                                           Margin="0,0,10,0" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding LoadText}"
                                                           Foreground="{Binding LoadBrush}"
                                                           HorizontalAlignment="Right"
                                                           FontSize="18"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="NoWrap" />
                                            </Grid>
                                            <ProgressBar Height="10" Value="{Binding Load}" Maximum="100" Margin="0,12,0,0" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border x:Name="IndicatorFootnote" Background="#12161E" BorderBrush="#2A3240" BorderThickness="1" CornerRadius="8" Padding="14" Visibility="Collapsed">
                            <TextBlock Style="{StaticResource MutedText}">
                                <Run Text="모든 시작을 응원하며 - 조마일즈" />
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>
