<Window x:Class="StreamDoumi.AddReadyItemWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="항목 추가"
        Icon="icon.ico"
        Width="520"
        Height="640"
        MinWidth="480"
        MinHeight="560"
        Background="#0F1117"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelAltBrush" Color="#20242E" />
        <SolidColorBrush x:Key="LineBrush" Color="#303642" />
        <SolidColorBrush x:Key="TextMainBrush" Color="#F5F7FA" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#9EA7B5" />
        <SolidColorBrush x:Key="AccentBrush" Color="#42D392" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#151922" />
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="Padding" Value="10,7" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#151922" />
            <Setter Property="Foreground" Value="#111111" />
            <Setter Property="Padding" Value="8,6" />
        </Style>

        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}" />
            <Setter Property="Background" Value="#252A35" />
            <Setter Property="BorderBrush" Value="#343B49" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="PillButton" BasedOn="{StaticResource GhostButton}" TargetType="Button">
            <Setter Property="Foreground" Value="#07110C" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock x:Name="DialogTitleText" Text="준비 항목 추가" FontSize="24" FontWeight="Bold" />
            <TextBlock x:Name="DialogDescriptionText"
                       Text="앱, 브라우저, 바로가기 중 하나를 등록합니다."
                       Foreground="{StaticResource TextMutedBrush}"
                       Margin="0,4,0,18" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock x:Name="TypeLabel" Text="종류" Margin="0,0,0,6" />
                <ComboBox x:Name="TypeComboBox" SelectionChanged="TypeComboBox_SelectionChanged" Margin="0,0,0,14">
                    <ComboBoxItem x:Name="AppTypeItem" Content="앱" Tag="App" IsSelected="True" />
                    <ComboBoxItem x:Name="BrowserTypeItem" Content="브라우저" Tag="Browser" />
                    <ComboBoxItem x:Name="ShortcutTypeItem" Content="바로가기" Tag="Shortcut" />
                </ComboBox>

                <StackPanel x:Name="BrowserPanel" Visibility="Collapsed">
                    <TextBlock x:Name="BrowserLabel" Text="브라우저" Margin="0,0,0,6" />
                    <ComboBox x:Name="BrowserComboBox" Margin="0,0,0,14">
                        <ComboBoxItem Content="Microsoft Edge" Tag="Edge" IsSelected="True" />
                        <ComboBoxItem Content="Google Chrome" Tag="Chrome" />
                        <ComboBoxItem Content="Brave" Tag="Brave" />
                        <ComboBoxItem Content="Firefox" Tag="Firefox" />
                        <ComboBoxItem Content="기본 브라우저" Tag="Default" />
                    </ComboBox>
                </StackPanel>

                <TextBlock x:Name="NameLabel" Text="표시 이름" Margin="0,0,0,6" />
                <TextBox x:Name="NameTextBox" Margin="0,0,0,14" />

                <StackPanel x:Name="PathPanel">
                    <TextBlock x:Name="PathLabel" Text="실행 파일" Margin="0,0,0,6" />
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="PathTextBox" />
                        <Button Grid.Column="1"
                                Style="{StaticResource GhostButton}"
                                x:Name="BrowseButton"
                                Content="찾기"
                                Click="BrowseButton_Click"
                                Margin="8,0,0,0" />
                    </Grid>
                </StackPanel>

                <StackPanel x:Name="UrlPanel" Visibility="Collapsed">
                    <TextBlock x:Name="UrlLabel" Text="URL" Margin="0,0,0,6" />
                    <TextBox x:Name="UrlTextBox" Margin="0,0,0,14" />

                    <TextBlock x:Name="BrowserProfileLabel" Text="브라우저 프로필 (선택)" Margin="0,0,0,6" />
                    <TextBox x:Name="BrowserProfileTextBox" Margin="0,0,0,14" />
                </StackPanel>

                <StackPanel x:Name="ArgumentsPanel">
                    <TextBlock x:Name="ArgumentsLabel" Text="실행 인자" Margin="0,0,0,6" />
                    <TextBox x:Name="ArgumentsTextBox" Margin="0,0,0,14" />
                </StackPanel>

                <CheckBox x:Name="RunAsAdminCheckBox"
                          Content="관리자 권한으로 실행"
                          Foreground="{StaticResource TextMainBrush}"
                          Margin="0,0,0,14" />

                <CheckBox x:Name="MinimizeAfterLaunchCheckBox"
                          Content="실행 후 최소화"
                          Foreground="{StaticResource TextMainBrush}"
                          Margin="0,0,0,14" />
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="CancelButton" Style="{StaticResource GhostButton}" Content="취소" Click="CancelButton_Click" Margin="0,0,8,0" />
            <Button x:Name="SaveButton" Style="{StaticResource PillButton}" Content="등록" Click="AddButton_Click" />
        </StackPanel>
    </Grid>
</Window>
